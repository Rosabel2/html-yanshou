      function showView(view) {
        if (view !== "audit") lastKnowledgeView = view;
        document.getElementById("viewUnitList").classList.toggle("is-active", view === "list");
        document.getElementById("viewUnitDetail").classList.toggle("is-active", view === "detail");
        document.getElementById("viewVoucherCollect").classList.toggle("is-active", view === "voucher");
        document.getElementById("viewAuditStart").classList.toggle("is-active", view === "audit");
        updateSubTabs(view);
      }

      function switchModule(module) {
        currentModule = module;
        document.querySelectorAll(".main-menu a[data-nav]").forEach(function (link) {
          link.classList.toggle("is-active", link.getAttribute("data-nav") === module);
        });
        var shell = document.getElementById("appShell");
        var assistant = document.getElementById("floatAssistant");
        if (module === "audit") {
          shell.classList.add("is-audit-mode");
          assistant.hidden = false;
          document.getElementById("viewUnitList").classList.remove("is-active");
          document.getElementById("viewUnitDetail").classList.remove("is-active");
          document.getElementById("viewVoucherCollect").classList.remove("is-active");
          document.getElementById("viewAuditStart").classList.add("is-active");
          updateSubTabs("audit");
        } else if (module === "knowledge") {
          shell.classList.remove("is-audit-mode");
          assistant.hidden = true;
          document.getElementById("viewAuditStart").classList.remove("is-active");
          showView(lastKnowledgeView);
        }
      }

      function updateSubTabs(view) {
        var tabs = document.querySelectorAll("#subTabs .tab");
        tabs.forEach(function (tab) {
          tab.classList.remove("is-active");
        });
        if (view === "audit") {
          document.getElementById("tabAuditStart").classList.add("is-active");
        } else if (view === "voucher") {
          document.getElementById("tabVoucher").classList.add("is-active");
        } else if (view === "list" || view === "detail") {
          document.querySelector('#subTabs .tab[data-tab="collect"]').classList.add("is-active");
        }
      }

      function getVouchersForScene(unitName, sceneName) {
        return VOUCHER_POOL.map(function (v, i) {
          var type = v.type || (i % 3 === 0 ? sceneName : "");
          return {
            id: "v-" + i,
            no: v.no,
            unit: unitName,
            month: v.month,
            type: type,
            status: "解析完成"
          };
        }).filter(function (v) {
          return !v.type || v.type === sceneName || v.type === "";
        });
      }

      function renderVouchers() {
        var unit = findUnit(currentUnitId);
        if (!unit) return;
        var all = getVouchersForScene(unit.name, currentSceneName);
        var f = voucherFilter;
        var list = all.filter(function (v) {
          if (f.unit && v.unit.indexOf(f.unit) < 0) return false;
          if (f.no && v.no.indexOf(f.no) < 0) return false;
          if (f.month && v.month !== f.month) return false;
          return true;
        });

        document.getElementById("voucherTotal").textContent = list.length;
        var grid = document.getElementById("voucherGrid");

        if (!list.length) {
          grid.innerHTML = '<div class="voucher-empty" data-figma="Empty/NoVoucher">暂无符合条件的记账凭证</div>';
          return;
        }

        grid.innerHTML = list.map(function (v) {
          var typeText = v.type || "--";
          var typeClass = v.type ? "" : " empty";
          return (
            '<article class="voucher-card" data-voucher-id="' + v.id + '" data-figma="Card/Voucher/' + v.id + '" data-axure="凭证卡片">' +
              '<div class="voucher-card-head">' +
                '<span>凭证号: ' + v.no + '</span>' +
                '<span class="status">' + v.status + '</span>' +
              '</div>' +
              '<div class="voucher-card-body">' +
                '<div class="voucher-row"><span class="lbl">核算单位</span><span class="val">' + v.unit + '</span></div>' +
                '<div class="voucher-row"><span class="lbl">凭证月份</span><span class="val">' + v.month + '</span></div>' +
                '<div class="voucher-row"><span class="lbl">类型</span><span class="val' + typeClass + '">' + typeText + '</span></div>' +
              '</div>' +
            '</article>'
          );
        }).join("");
      }

      function openVoucherCollect(sceneId, sceneName) {
        currentSceneId = sceneId;
        currentSceneName = sceneName;
        var unit = findUnit(currentUnitId);
        if (!unit) return;

        voucherFilter = { unit: unit.name };
        document.getElementById("vfUnit").value = unit.name;
        document.getElementById("vfNo").value = "";
        document.getElementById("vfMonth").value = "";

        renderVouchers();
        showView("voucher");
      }

      function renderScenes() {
        var scenes = unitScenes[currentUnitId] || [];
        var grid = document.getElementById("sceneGrid");
        document.getElementById("sceneCount").textContent = scenes.length;

        if (!scenes.length) {
          grid.innerHTML =
            '<div class="scene-empty" data-figma="Empty/NoScene">' +
              '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="8" y="12" width="32" height="28" rx="4" stroke="#91d5ff" stroke-width="2"/><path d="M16 22h16M16 28h10" stroke="#91d5ff" stroke-width="2" stroke-linecap="round"/></svg>' +
              '<span>暂无查账场景，请点击「新增类型」添加</span>' +
            '</div>';
          return;
        }

        var unit = findUnit(currentUnitId);

        grid.innerHTML = scenes.map(function (s) {
          var voucherCount = unit ? getVouchersForScene(unit.name, s.name).length : 0;
          return (
            '<article class="scene-card" data-scene-id="' + s.id + '" data-figma="Card/Scene/' + s.id + '" data-axure="场景卡片">' +
              '<div class="scene-card-top"><h4>' + s.name + '</h4></div>' +
              '<p class="scene-desc">' + s.desc + '</p>' +
              '<div class="scene-card-foot">' +
                '<span class="scene-voucher-count" data-figma="Scene/VoucherCount"><strong>' + voucherCount + '</strong> 张凭证</span>' +
                '<div class="scene-actions">' +
                  '<button type="button" class="btn-view" data-action="view" data-axure="查看">查看</button>' +
                  '<button type="button" class="btn-edit" data-action="edit" data-axure="编辑">编辑</button>' +
                  '<button type="button" class="btn-delete" data-action="delete" data-axure="删除">删除</button>' +
                '</div>' +
              '</div>' +
            '</article>'
          );
        }).join("");

        grid.querySelectorAll('[data-action="delete"]').forEach(function (btn) {
          btn.addEventListener("click", function (e) {
            e.stopPropagation();
            openDeleteSceneModal(btn.closest(".scene-card").getAttribute("data-scene-id"));
          });
        });

        grid.querySelectorAll('[data-action="edit"]').forEach(function (btn) {
          btn.addEventListener("click", function (e) {
            e.stopPropagation();
            openEditSceneModal(btn.closest(".scene-card").getAttribute("data-scene-id"));
          });
        });

        grid.querySelectorAll(".scene-card").forEach(function (card) {
          card.addEventListener("click", function () {
            var sid = card.getAttribute("data-scene-id");
            var scene = (unitScenes[currentUnitId] || []).find(function (s) { return s.id === sid; });
            if (scene) openVoucherCollect(scene.id, scene.name);
          });
        });
      }

      function openUnitDetail(unitId) {
        var unit = findUnit(unitId);
        if (!unit) return;
        currentUnitId = unitId;
        document.getElementById("detailUnitName").textContent = unit.name;
        document.getElementById("detailUnitMeta").textContent = "统一社会信用代码：" + unit.code;
        renderScenes();
        showView("detail");
      }

      function updateDescCounter(textareaId, counterId) {
        var el = document.getElementById(textareaId);
        var countEl = document.getElementById(counterId);
        if (!el || !countEl) return;
        var len = el.value.length;
        countEl.textContent = len + "/" + DESC_MAX;
        countEl.classList.toggle("is-limit", len >= DESC_MAX);
      }

      function openAddModal() {
        document.getElementById("sceneName").value = "";
        document.getElementById("sceneDesc").value = "";
        updateDescCounter("sceneDesc", "sceneDescCount");
        document.getElementById("addSceneModal").classList.add("is-open");
      }

      function closeAddModal() {
        document.getElementById("addSceneModal").classList.remove("is-open");
      }

      function openEditSceneModal(sceneId) {
        var scene = (unitScenes[currentUnitId] || []).find(function (s) { return s.id === sceneId; });
        if (!scene) return;
        pendingEditSceneId = sceneId;
        document.getElementById("editSceneName").value = scene.name;
        document.getElementById("editSceneDesc").value = scene.desc;
        updateDescCounter("editSceneDesc", "editSceneDescCount");
        document.getElementById("editSceneModal").classList.add("is-open");
      }

      function closeEditSceneModal() {
        pendingEditSceneId = null;
        document.getElementById("editSceneModal").classList.remove("is-open");
      }

      function confirmEditScene() {
        if (!pendingEditSceneId) return;
        var name = document.getElementById("editSceneName").value.trim();
        var desc = document.getElementById("editSceneDesc").value.trim();
        if (!name) {
          alert("请输入类型名称");
          return;
        }
        if (!desc) {
          alert("请输入类型描述");
          return;
        }
        if (desc.length > DESC_MAX) {
          alert("类型描述最多50字");
          return;
        }
        var scenes = unitScenes[currentUnitId] || [];
        var duplicate = scenes.some(function (s) {
          return s.id !== pendingEditSceneId && s.name === name;
        });
        if (duplicate) {
          alert("该类型名称已存在，请更换");
          return;
        }
        var scene = scenes.find(function (s) { return s.id === pendingEditSceneId; });
        if (scene) {
          scene.name = name;
          scene.desc = desc;
        }
        closeEditSceneModal();
        renderScenes();
      }

      function openDeleteSceneModal(sceneId) {
        pendingDeleteSceneId = sceneId;
        var scene = (unitScenes[currentUnitId] || []).find(function (s) { return s.id === sceneId; });
        var unit = findUnit(currentUnitId);
        var count = unit && scene ? getVouchersForScene(unit.name, scene.name).length : 0;
        document.getElementById("deleteSceneMsg").innerHTML =
          "该类型存在<strong>" + count + "</strong>份凭证将同步删除，确认删除？";
        document.getElementById("deleteSceneModal").classList.add("is-open");
      }

      function closeDeleteSceneModal() {
        pendingDeleteSceneId = null;
        document.getElementById("deleteSceneModal").classList.remove("is-open");
      }

      function confirmDeleteScene() {
        if (!pendingDeleteSceneId) return;
        unitScenes[currentUnitId] = unitScenes[currentUnitId].filter(function (s) {
          return s.id !== pendingDeleteSceneId;
        });
        closeDeleteSceneModal();
        renderScenes();
      }

      function confirmAddScene() {
        var name = document.getElementById("sceneName").value.trim();
        var desc = document.getElementById("sceneDesc").value.trim();
        if (!name) {
          alert("请输入类型名称");
          return;
        }
        if (!desc) {
          alert("请输入类型描述");
          return;
        }
        if (desc.length > DESC_MAX) {
          alert("类型描述最多50字");
          return;
        }
        var existing = (unitScenes[currentUnitId] || []).map(function (s) { return s.name; });
        if (existing.indexOf(name) >= 0) {
          alert("该场景已存在，请勿重复添加");
          return;
        }
        var tpl = getTemplate(name);
        sceneIdSeq += 1;
        unitScenes[currentUnitId].push({
          id: "sc-new-" + sceneIdSeq,
          name: name,
          desc: desc,
          color: tpl.color,
          icon: tpl.icon
        });
        renderScenes();
        closeAddModal();
      }

