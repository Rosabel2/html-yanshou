      function defaultScenes() {
        return SCENE_TEMPLATES.map(function (t, i) {
          return { id: "sc-" + (i + 1), name: t.name, desc: t.desc, color: t.color, icon: t.icon };
        });
      }

      function initUnitScenes() {
        UNITS.forEach(function (u) {
          unitScenes[u.id] = defaultScenes();
        });
      }

      function getTemplate(name) {
        return SCENE_TEMPLATES.find(function (t) { return t.name === name; }) || {
          name: name, desc: "自定义审计查账场景", color: "c-blue", icon: "📌"
        };
      }

      function findUnit(id) {
        return UNITS.find(function (u) { return u.id === id; });
      }

      function renderUnitGrid(filter) {
        var grid = document.getElementById("unitGrid");
        var keyword = (filter || "").trim().toLowerCase();
        var list = UNITS.filter(function (u) {
          return !keyword || u.name.toLowerCase().indexOf(keyword) >= 0;
        });

        grid.innerHTML = list.map(function (u) {
          return (
            '<article class="unit-card" data-unit-id="' + u.id + '" data-figma="Card/Unit/' + u.id + '" data-axure="单位卡片">' +
              '<div class="unit-card-head"><h3>' + u.name + '</h3>' +
              '<span class="size-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="4" r="2" stroke="currentColor" stroke-width="1"/><path d="M2 10c0-2.2 1.8-3 4-3s4 .8 4 3" stroke="currentColor" stroke-width="1"/></svg>' + u.size + '</span></div>' +
              '<div class="unit-meta">' +
                '<div class="unit-meta-row"><svg class="meta-icon" viewBox="0 0 16 16" fill="none"><path d="M8 1l2 4 4.5.5-3.2 3 1 4.5L8 11.5 3.7 13l1-4.5L1.5 5.5 6 5z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/></svg><span class="meta-text">' + u.code + '</span></div>' +
                '<div class="unit-meta-row"><svg class="meta-icon" viewBox="0 0 16 16" fill="none"><path d="M8 8.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z" stroke="currentColor" stroke-width="1.1"/><path d="M8 14s5-3.5 5-7a5 5 0 10-10 0c0 3.5 5 7 5 7z" stroke="currentColor" stroke-width="1.1"/></svg><span class="meta-text">' + u.address + '</span></div>' +
              '</div>' +
              '<div class="contact-row">' + u.contacts.map(function (c) {
                return '<div class="contact-box ' + c.type + '"><div class="contact-name">' + c.name + '</div><div class="contact-phone">' + c.phone + '</div></div>';
              }).join("") + '</div>' +
            '</article>'
