      function getAuditUnitName() {
        var unit = findUnit(AUDIT_UNIT_ID);
        return unit ? unit.name : "";
      }

      function openLinkVoucherDrawer() {
        lvUnitSelect.setDefault();
        lvTypeSelect.refreshOptions();
        document.getElementById("linkVoucherDrawer").classList.add("is-open");
      }

      function closeLinkVoucherDrawer() {
        lvUnitSelect.close();
        lvTypeSelect.close();
        document.getElementById("linkVoucherDrawer").classList.remove("is-open");
      }

      var lvUnitSelect = {
        value: "",

        getOptions: function () {
          return UNITS.map(function (u) { return u.name; });
        },

        refreshOptions: function () {
          this.renderList("");
        },

        renderList: function (keyword) {
          var list = document.getElementById("lvUnitList");
          var options = this.getOptions();
          var kw = (keyword || "").trim().toLowerCase();
          var filtered = options.filter(function (name) {
            return !kw || name.toLowerCase().indexOf(kw) !== -1;
          });
          list.innerHTML = "";
          if (!filtered.length) {
            var empty = document.createElement("li");
            empty.className = "is-empty";
            empty.textContent = "无匹配单位";
            list.appendChild(empty);
            return;
          }
          var self = this;
          filtered.forEach(function (name) {
            var li = document.createElement("li");
            li.textContent = name;
            if (name === self.value) li.classList.add("is-active");
            li.addEventListener("mousedown", function (e) {
              e.preventDefault();
              self.setValue(name);
              self.close();
            });
            list.appendChild(li);
          });
        },

        setValue: function (val) {
          this.value = val || "";
          document.getElementById("lvUnit").value = this.value;
          var label = document.getElementById("lvUnitLabel");
          if (this.value) {
            label.textContent = this.value;
            label.classList.remove("is-placeholder");
          } else {
            label.textContent = "请选择 核算单位";
            label.classList.add("is-placeholder");
          }
        },

        setDefault: function () {
          this.setValue(getAuditUnitName());
          document.getElementById("lvUnitSearch").value = "";
          this.renderList("");
        },

        clear: function () {
          this.setValue("");
          document.getElementById("lvUnitSearch").value = "";
          this.renderList("");
        },

        open: function () {
          document.getElementById("lvUnitSelect").classList.add("is-open");
          this.refreshOptions();
          var search = document.getElementById("lvUnitSearch");
          search.value = "";
          search.focus();
        },

        close: function () {
          document.getElementById("lvUnitSelect").classList.remove("is-open");
          document.getElementById("lvUnitSearch").value = "";
        },

        toggle: function () {
          if (document.getElementById("lvUnitSelect").classList.contains("is-open")) {
            this.close();
          } else {
            this.open();
          }
        }
      };

      document.getElementById("lvUnitTrigger").addEventListener("click", function (e) {
        e.stopPropagation();
        lvUnitSelect.toggle();
      });

      document.getElementById("lvUnitSearch").addEventListener("input", function () {
        lvUnitSelect.renderList(this.value);
      });

      document.getElementById("lvUnitSearch").addEventListener("click", function (e) {
        e.stopPropagation();
      });

      var lvTypeSelect = {
        value: "",

        getOptions: function () {
          var scenes = unitScenes[AUDIT_UNIT_ID] || defaultScenes();
          return scenes.map(function (s) { return s.name; });
        },

        refreshOptions: function () {
          this.renderList("");
        },

        renderList: function (keyword) {
          var list = document.getElementById("lvTypeList");
          var options = this.getOptions();
          var kw = (keyword || "").trim().toLowerCase();
          var filtered = options.filter(function (name) {
            return !kw || name.toLowerCase().indexOf(kw) !== -1;
          });
          list.innerHTML = "";
          if (!filtered.length) {
            var empty = document.createElement("li");
            empty.className = "is-empty";
            empty.textContent = "无匹配类型";
            list.appendChild(empty);
            return;
          }
          var self = this;
          filtered.forEach(function (name) {
            var li = document.createElement("li");
            li.textContent = name;
            if (name === self.value) li.classList.add("is-active");
            li.addEventListener("mousedown", function (e) {
              e.preventDefault();
              self.setValue(name);
              self.close();
            });
            list.appendChild(li);
          });
        },

        setValue: function (val) {
          this.value = val || "";
          document.getElementById("lvType").value = this.value;
          var label = document.getElementById("lvTypeLabel");
          if (this.value) {
            label.textContent = this.value;
            label.classList.remove("is-placeholder");
          } else {
            label.textContent = "请选择 类型";
            label.classList.add("is-placeholder");
          }
        },

        clear: function () {
          this.setValue("");
          document.getElementById("lvTypeSearch").value = "";
          this.renderList("");
        },

        open: function () {
          document.getElementById("lvTypeSelect").classList.add("is-open");
          this.refreshOptions();
          var search = document.getElementById("lvTypeSearch");
          search.value = "";
          search.focus();
        },

        close: function () {
          document.getElementById("lvTypeSelect").classList.remove("is-open");
          document.getElementById("lvTypeSearch").value = "";
        },

        toggle: function () {
          if (document.getElementById("lvTypeSelect").classList.contains("is-open")) {
            this.close();
          } else {
            this.open();
          }
        }
      };

      document.getElementById("lvTypeTrigger").addEventListener("click", function (e) {
        e.stopPropagation();
        lvTypeSelect.toggle();
      });

      document.getElementById("lvTypeSearch").addEventListener("input", function () {
        lvTypeSelect.renderList(this.value);
      });

      document.getElementById("lvTypeSearch").addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function (e) {
        if (!document.getElementById("lvUnitSelect").contains(e.target)) {
          lvUnitSelect.close();
        }
        if (!document.getElementById("lvTypeSelect").contains(e.target)) {
          lvTypeSelect.close();
        }
      });

      document.getElementById("btnLinkVoucher").addEventListener("click", function (e) {
        e.stopPropagation();
        openLinkVoucherDrawer();
      });

      document.getElementById("linkVoucherCloseBtn").addEventListener("click", closeLinkVoucherDrawer);
      document.getElementById("linkVoucherCancelBtn").addEventListener("click", closeLinkVoucherDrawer);
      document.getElementById("linkVoucherSaveBtn").addEventListener("click", function () {
        closeLinkVoucherDrawer();
      });
      document.getElementById("linkVoucherDrawer").addEventListener("click", function (e) {
        if (e.target === this) closeLinkVoucherDrawer();
      });

      document.getElementById("lvCheckAll").addEventListener("change", function () {
        var checked = this.checked;
        document.querySelectorAll(".lv-row-check").forEach(function (cb) {
          cb.checked = checked;
        });
      });

      document.getElementById("lvResetBtn").addEventListener("click", function () {
        lvUnitSelect.setDefault();
        document.getElementById("lvNo").value = "";
        document.getElementById("lvMonth").value = "";
        lvTypeSelect.clear();
      });

      document.getElementById("lvSearchBtn").addEventListener("click", function () {
        /* 原型演示：筛选逻辑省略 */
      });
    })();
  </script>
</body>
</html>
